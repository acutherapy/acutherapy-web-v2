{
  "redirects": [

    {
      "source": "/acupuncture-honolulu",
      "destination": "/services/acupuncture",
      "permanent": true
    },
    {
      "source": "/medical-massage",
      "destination": "/services/massage",
      "permanent": true
    },
    {
      "source": "/auto-injury",
      "destination": "/conditions/auto-accident",
      "permanent": true
    },

    {
      "source": "/page-sitemap.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemap_index.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    },

    {
      "source": "/zh/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/cn/:path*",
      "destination": "/",
      "permanent": true
    },

    {
      "source": "/category/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tag/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/author/:path*",
      "destination": "/",
      "permanent": true
    },

    {
      "source": "/:year/:month/:slug",
      "destination": "/",
      "permanent": true
    }

  ],

  "rewrites": [

    {
      "source": "/go/review",
      "destination": "/api/go/review"
    },
    {
      "source": "/go/video",
      "destination": "/api/go/video"
    },
    {
      "source": "/go/book",
      "destination": "/api/go/book"
    },

    {
      "source": "/robots.txt",
      "has": [
        {
          "type": "host",
          "value": "(.*)\\.vercel\\.app"
        }
      ],
      "destination": "/vercel-robots.txt"
    }

  ]
}
