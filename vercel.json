  "rewrites": [
    {
      "source": "/go/review",
      "destination": "/api/go/review"
    },
    {
      "source": "/go/video",
      "destination": "/api/go/video"
    },
    {
      "source": "/go/book",
      "destination": "/api/go/book"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(?:en|zh)/landing/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "none"
        }
      ]
    },
    {
      "source": "/go/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
