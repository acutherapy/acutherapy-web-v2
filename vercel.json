        }
      ],
      "destination": "https://acutherapy.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "acutherapy-web.vercel.app"
        }
      ],
      "destination": "https://acutherapy.com/$1",
      "permanent": true
    }
